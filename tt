#!/bin/bash

#./clean

#git pull

CERT_BUNDLE="/etc/pki/tls/certs/ca-bundle.crt"
if [ ! -f "${CERT_BUNDLE}" ]; then
    echo "Error: ${CERT_BUNDLE} is not found."
    exit 99
fi

export PATH=${PATH}:"`pwd`/bin"

### in build folder
if [ ! -d "./build" ]; then
	mkdir build
fi

cd build

echo "Installing build dependencies using Conan..."
conan install .. --build=missing -cc core.net.http:cacert_path="${CERT_BUNDLE}"

echo "Executing cmake in \'`pwd`\'..."
cmake .. -G "Unix Makefiles" -DCMAKE_TOOLCHAIN_FILE="`pwd`/Release/generators/conan_toolchain.cmake" -DCMAKE_POLICY_DEFAULT_CMP0091=NEW -DCMAKE_BUILD_TYPE=Release

#echo "Setting up environment..."
#source ./Release/generators/conanbuild.sh
echo "Setting up environment..."
source ./Release/generators/conanbuild.sh

echo "Executing cmake --build in \'`pwd`\'..."
cmake --build .

echo "Executing ctest in \'`pwd`\'..."
ctest --test-dir test

echo "Tearing down environment..."
source ./Release/generators/deactivate_conanbuild.sh
